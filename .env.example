# Local DB
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=konfirmasi123
# DB_DATABASE=maxwell-local

# Database (Supabase)
# Copy the URI from: Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Pooler hostname is per-project/region (e.g. aws-0-ap-southeast-1 vs aws-1-...); do not guess it.
#
# If Nest logs: getaddrinfo ENOTFOUND *.pooler.supabase.com → DNS cannot resolve the host (wrong
# hostname, offline/VPN/DNS issue). Copy the pooler host exactly from the dashboard (aws-0 vs aws-1).
# Until the DB is reachable, ALL /fe APIs fail — including Finance (ledger, payouts, refunds).
#
# SSL: Supabase requires TLS. The app enables ssl for *.supabase.com URLs automatically; you can
# also set DB_SSL=true or append ?sslmode=require to DATABASE_URL.
#
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# DB_SSL=true
# Kalau log: "Connection terminated due to connection timeout" (TypeORM / pg): host tidak terjangkau,
# VPN/firewall, atau pooler salah. Coba: naikkan timeout `DB_CONNECTION_TIMEOUT_MS=60000`, pastikan
# hostname pooler persis dari Supabase Dashboard, lalu `npm run test:db` atau `psql "$DATABASE_URL" -c 'select 1'`.
# Postgres lokal: pakai `DB_HOST=localhost` + hapus/comment `DATABASE_URL`, atau `DATABASE_URL` ke localhost.
# Quick check (no Nest): npm run test:db
# Contract Center tables (clause library, templates, instances):
#   psql "$DATABASE_URL" -f database/migrations/017_contracts_documents.sql
# Store / marketplace (pricing_rules feRuleId, discounts feId, inventory_transactions feId):
#   psql "$DATABASE_URL" -f database/migrations/018_store_marketplace_fe_ids.sql
#   psql "$DATABASE_URL" -f database/migrations/019_inventory_transactions_fe_id.sql
# Master Commission Rules → table fe_commission_rules (`/fe/commission-rules` when FE COMMERCE=API):
#   psql "$DATABASE_URL" -f database/migrations/020_commission_rules_fe.sql
# Finance Forecast tab (FE): GET `/fe/store/finance-forecast` aggregates payment_transactions, transactions, payout_transactions (no extra migration).
#
# --- Automation queue (Postgres, no Redis) ---
# Nest runs `@nestjs/schedule` worker: every 10s claims one `automation_queue` PENDING row (SKIP LOCKED),
# executes server handlers (e.g. EMAIL → Resend via CommunicationEmailService), sets COMPLETED/FAILED.
# Disable on dev if you only want the FE piggyback worker: DISABLE_AUTOMATION_QUEUE_WORKER=true
# Optional: max jobs drained per 10s tick (default 8): AUTOMATION_QUEUE_BURST_PER_TICK=8
#
# --- Store checkout → wallet (server-side entitlements) ---
# Apply on the same Postgres used by Nest BEFORE deploying code that writes buyerUserId / processes entitlements:
#   psql "$DATABASE_URL" -f database/migrations/031_payment_transactions_buyer_entitlement.sql
# Production / staging testing checklist:
#   1. Migration applied (columns buyerUserId, entitlementProcessed, entitlementProcessedAt).
#   2. FE sends Bearer on POST /transactions/midtrans/snap when user is logged in (buyerUserId stored).
#   3. Midtrans Notification URL points to POST /webhooks/midtrans (HTTPS, reachable from Midtrans).
#   4. Staging on prod-like NODE_ENV: set ALLOW_PAYMENT_SIMULATION=true explicitly, or use real Midtrans sandbox.
#   5. Wallet grant is idempotent: duplicate webhooks or retries do not duplicate wallet rows.


# Midtrans - Sandbox (satutitik engineer)
MIDTRANS_MERCHANT_ID=G094827867
MIDTRANS_CLIENT_KEY=Mid-client-le5XU8hDHcDSkS97
MIDTRANS_SERVER_KEY=YOUR_MIDTRANS_SERVER_KEY
MIDTRANS_IS_PRODUCTION=false

# Payments pricing
# PPN/VAT rate used by backend pricing. Default 0% for now.
PAYMENT_PPN_RATE_PERCENT=0

# Simulate-settle (modal checkout without Midtrans). If unset, the API infers: ON for local &
# Vercel preview, OFF for NODE_ENV=production (e.g. Railway prod) and Vercel Production.
# Uncomment to force ON/OFF regardless of host (e.g. staging on Railway with NODE_ENV=production → true).
# ALLOW_PAYMENT_SIMULATION=true

# App
PORT=3002
NODE_ENV=development
# Kalender operasional Indonesia (WIB): event `DATE` di API selalu `YYYY-MM-DD` via SQL `to_char`
# (bukan midnight UTC). Untuk timestamp/log Node konsisten WIB, set opsional:
# TZ=Asia/Jakarta

# Optional: when set, `POST /fe/internal/members/sync` is enabled and requires header `x-internal-key`
# with this exact value (share the same secret in Next.js server env — never NEXT_PUBLIC_*).
# INTERNAL_MEMBER_SYNC_KEY=

# Comma-separated browser origins allowed to call the API (Railway / production).
# Must include your Vercel URL or the dashboard will get CORS errors.
# APP_CORS_ORIGINS=http://localhost:3000,https://maxwellenterpricev2.vercel.app

# --- Notifikasi Midtrans saat development lokal ---
# Midtrans butuh URL publik untuk kirim webhook (localhost tidak bisa diakses dari internet).
# Pakai tunnel (ngrok):
#   1. Install: https://ngrok.com/download  lalu jalankan:  ngrok http 3000
#   2. Copy URL HTTPS (mis. https://abc123.ngrok-free.app)
#   3. Midtrans Dashboard (Sandbox) → Settings → Configuration →
#      Notification URL: https://abc123.ngrok-free.app/webhooks/midtrans
# Setiap kali restart ngrok, URL berubah; update lagi di dashboard kalau perlu.

# --- Workspace auth (Nest JWT + magic link + Google) ---
# Di Google Cloud → OAuth client → Authorized redirect URIs harus persis (bukan origin saja):
#   https://<railway-host>/fe/auth/google/callback
#   http://localhost:3000/fe/auth/google/callback
# FRONTEND_URL=https://your-app.vercel.app
# Development safety (default): non-local FRONTEND_URL / GOOGLE_REDIRECT_URI are ignored and fallback to localhost.
# Set true only when you intentionally test OAuth redirect to non-local host while NODE_ENV=development.
# ALLOW_NON_LOCAL_AUTH_REDIRECT_IN_DEV=true
# JWT_SECRET=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=
# Lokal: GOOGLE_REDIRECT_URI=http://localhost:3000/fe/auth/google/callback
# Di production, redirect Google ke Nest langsung (hindari /fe di Vercel tanpa proxy):
# GOOGLE_REDIRECT_URI=https://your-nest.up.railway.app/fe/auth/google/callback
# Link di email magic: origin publik Nest (sama dengan host di GOOGLE_REDIRECT_URI tanpa path):
# AUTH_BACKEND_ORIGIN=https://your-nest.up.railway.app
# Magic link email (Resend — https://resend.com/api-keys )
# Tanpa RESEND_API_KEY, POST /fe/auth/email/send mengembalikan 401.
# EMAIL_FROM default di kode: onboarding@resend.dev — pakai itu atau domain yang sudah diverifikasi di Resend.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=onboarding@resend.dev
# Transactional automation (Welcome Email, dll.): POST /fe/communication/email/send-by-trigger juga memakai RESEND_API_KEY + EMAIL_FROM.
# Opsional: branding email magic link (default Maxwell Leadership Enterprise + logo GitHub avatar)
# EMAIL_BRAND_NAME=Maxwell Leadership Enterprise
# EMAIL_LOGO_URL=https://...
# Subject inbox (default: Account access verification — Maxwell Leadership Enterprise)
# EMAIL_SUBJECT=Account access verification — Maxwell Leadership Enterprise
# Link footer (Kunjungi Website, dll.) — pakai URL publik FE (Vercel), terpisah dari FRONTEND_URL lokal:
# EMAIL_PUBLIC_BASE_URL=https://maxwellenterpricev2.vercel.app
# Workspace role-invite policy (default in code):
# - invite expiry: none (valid until consumed/replaced)
# - invitable roles: Super Admin, Finance, Operations, Marketing, Sales, Member
# - non-invitable via this endpoint: Guest, Gate Keeper, Facilitator
# APP_ADMIN_EMAILS=admin@example.com

# --- Supabase (optional; Storage + Realtime Broadcast for campaign metrics) ---
# Dashboard live metrics: Nest uses service role to emit Broadcast; never expose this key to the browser.
# Copy from Supabase Dashboard → Project Settings → API.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Harus JWT "service_role" lengkap (Reveal), bukan JWT Secret / password DB. Tanpa kutip, tanpa
# "Bearer ", tanpa baris baru di tengah string — kalau tidak, Storage bisa error "Invalid Compact JWS".
# Nest memaksa header Storage memakai service_role (bukan session getSession()) supaya aman di server.
# SUPABASE_STORAGE_BUCKET=app-images
# Kalau upload error "violates row-level security policy": jalankan SQL di
#   database/supabase-sql/storage_app_images_rls.sql
#   pada Supabase SQL Editor (bukan DB Maxwell).
# Local dev: set to silence Realtime TIMED_OUT retries when you are not using live campaign broadcast:
# DISABLE_CAMPAIGN_METRICS_BROADCAST=1
# Account deletion queue (Super Admin) + profile deletion-status realtime broadcast:
# DISABLE_ACCOUNT_DELETION_BROADCAST=1

