# Local DB
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=konfirmasi123
# DB_DATABASE=maxwell-local

# Database (Supabase)
# Copy the URI from: Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Pooler hostname is per-project/region (e.g. aws-0-ap-southeast-1 vs aws-1-...); do not guess it.
#
# If Nest logs: getaddrinfo ENOTFOUND *.pooler.supabase.com → DNS cannot resolve the host (wrong
# hostname, offline/VPN/DNS issue). Copy the pooler host exactly from the dashboard (aws-0 vs aws-1).
# Until the DB is reachable, ALL /fe APIs fail — including Finance (ledger, payouts, refunds).
#
# SSL: Supabase requires TLS. The app enables ssl for *.supabase.com URLs automatically; you can
# also set DB_SSL=true or append ?sslmode=require to DATABASE_URL.
#
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# DB_SSL=true
# Quick check (no Nest): npm run test:db
# Contract Center tables (clause library, templates, instances):
#   psql "$DATABASE_URL" -f database/migrations/017_contracts_documents.sql
# Store / marketplace (pricing_rules feRuleId, discounts feId, inventory_transactions feId):
#   psql "$DATABASE_URL" -f database/migrations/018_store_marketplace_fe_ids.sql
#   psql "$DATABASE_URL" -f database/migrations/019_inventory_transactions_fe_id.sql
# Master Commission Rules → table fe_commission_rules (`/fe/commission-rules` when FE COMMERCE=API):
#   psql "$DATABASE_URL" -f database/migrations/020_commission_rules_fe.sql
# Finance Forecast tab (FE): GET `/fe/store/finance-forecast` aggregates payment_transactions, transactions, payout_transactions (no extra migration).


# Midtrans - Sandbox (satutitik engineer)
MIDTRANS_MERCHANT_ID=G094827867
MIDTRANS_CLIENT_KEY=Mid-client-le5XU8hDHcDSkS97
