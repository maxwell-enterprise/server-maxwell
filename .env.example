# Payments pricing
# PPN/VAT rate used by backend pricing. Default 0% for now.
PAYMENT_PPN_RATE_PERCENT=0

# App
PORT=3002
NODE_ENV=development

# Comma-separated browser origins allowed to call the API (Railway / production).
# Must include your Vercel URL or the dashboard will get CORS errors.
# APP_CORS_ORIGINS=http://localhost:3000,https://maxwellenterpricev2.vercel.app

# --- Notifikasi Midtrans saat development lokal ---
# Midtrans butuh URL publik untuk kirim webhook (localhost tidak bisa diakses dari internet).
# Pakai tunnel (ngrok):
#   1. Install: https://ngrok.com/download  lalu jalankan:  ngrok http 3000
#   2. Copy URL HTTPS (mis. https://abc123.ngrok-free.app)
#   3. Midtrans Dashboard (Sandbox) → Settings → Configuration →
#      Notification URL: https://abc123.ngrok-free.app/webhooks/midtrans
# Setiap kali restart ngrok, URL berubah; update lagi di dashboard kalau perlu.

